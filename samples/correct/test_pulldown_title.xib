        <customView id="2">
            <rect key="frame" x="0.0" y="0.0" width="200" height="50"/>
            <subviews>
                <popUpButton verticalHuggingPriority="750" id="3">
                    <rect key="frame" x="5" y="5" width="100" height="17"/>
