        <window title="T" allowsToolTipsWhenApplicationIsInactive="NO" autorecalculatesKeyViewLoop="NO" releasedWhenClosed="NO" animationBehavior="default" id="w1">
            <windowStyleMask key="styleMask" titled="YES" closable="YES"/>
            <rect key="contentRect" x="100" y="100" width="300" height="200"/>
            <rect key="screenRect" x="0.0" y="0.0" width="1920" height="1080"/>
